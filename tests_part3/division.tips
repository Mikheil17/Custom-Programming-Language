PROGRAM DIVISION;
VAR
  X : INTEGER;
  Y : INTEGER;
BEGIN
  X := ((18 * -4) - (6 + -3) * 5 + (42 / -2) - (7 * (3 - 5)) + (-8 * 2) - -11);
  Y := (((9 * -3) - -27) + ((14 - 4) / -2) - -5 + (6 * -3) - -18 + (2 * (7 - 12)) - -10);
  X /= Y;
  WRITE(X);
